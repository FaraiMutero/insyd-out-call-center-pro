NODE_ENV=development
PORT=4000
APP_SECRET=replace-with-strong-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
DB_FILE=./data/app.db

# ── Transcription provider: azure | whisper ──────────────────────────────
TRANSCRIPTION_PROVIDER=azure

# Azure Speech (required when TRANSCRIPTION_PROVIDER=azure)
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastus
# AZURE_SPEECH_LANGUAGE=en-US

# ── Analysis provider: deepseek | openai_compatible | anthropic ─────────
ANALYSIS_PROVIDER=anthropic

# DeepSeek (required when ANALYSIS_PROVIDER=deepseek)
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# Generic OpenAI-compatible endpoint (required when ANALYSIS_PROVIDER=openai_compatible)
# OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_MODEL=gpt-4o-mini

# Anthropic (required when ANALYSIS_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=
